#include <cstdio>
#include <cstdlib>
#include <iostream>
#include <stdio.h>


class humiditySensor {
	private: 
		double readingHistory[2][20];
		double reading[2][1];
		int sensorID;
	public:
		void storeReading(double humidity, double unix){
			if(humidity>100){
				std::cout << "\n error: humidity > 100%. Reading dropped \n" << std::endl;
			}
			else if(humidity<0){
				std::cout << "\n error: humidity < 0%. Reading dropped \n" << std::endl;
			}
			else{
			
			for(int i=18; i>-1; i--){
				readingHistory[0][i+1]=readingHistory[0][i];
				readingHistory[1][i+1]=readingHistory[1][i];
			}
			readingHistory[0][0]=humidity;
			readingHistory[1][0]=unix;
			reading[0][0]=humidity;
			reading[1][0]=unix;
		}
		}
		double getReading(){
			double temp=reading[0][0];
			return temp;
		
		}
		void History(){
			for(int i=0; i<20; i++){
				std::cout << readingHistory[0][i] << "%  at" << readingHistory[1][i] << "\n" << std::endl; 
				
			}
			
		}
		void setID(int ID){
			sensorID=ID;
		}
		int getID(){
			return sensorID;
		}
		~humiditySensor(){
			std::cout <<" destructor called \n" << std::endl; 
		}
	
	
	
	
	
};


int main(){
	humiditySensor S1;
	humiditySensor S2;
	double humidity;
	double magicNumber1;
	double magicNumber2;
	magicNumber1=0.873;
	magicNumber2=1.132;
	for(int i=0; i<30; i++){
		double temp = i + rand() % 200 - 100;
		humidity = magicNumber1 * temp;
		S1.storeReading(humidity, i);
		
	}
	printf("\n S1 readings: \n");
	S1.History();
	printf("\n complete \n");
	
	for(int i=0; i<40; i++){
		double temp = i + rand() % 200 - 100;
		humidity = magicNumber2 * temp;
		S2.storeReading(humidity, i);
		
	}
	printf("\n S2 readings: \n");
	S2.History();
	printf("\n complete \n");
	

	
	
	return 0;
	
	
	
	
}
